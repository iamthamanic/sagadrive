# ===========================================
# SagaDrive Self-Host Configuration
# Copy this file to .env and fill in values
# ===========================================

# Generate with: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-change-me-in-production

# PostgreSQL Password
POSTGRES_PASSWORD=your-super-secret-password-change-me

# Generate with: openssl rand -base64 32
SUPABASE_ANON_KEY=your-anon-key-change-me
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-change-me

# Site URL
SITE_URL=http://localhost:3000
ADDITIONAL_REDIRECT_URLS=http://localhost:3000/auth/callback

# SMTP (optional, for email)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-email-password
# SMTP_ADMIN_EMAIL=admin@example.com

# Email confirmation (set to false for production)
MAILER_AUTOCONFIRM=true
DISABLE_SIGNUP=false

# Neo4j Password
NEO4J_PASSWORD=your-neo4j-password-change-me

# Ollama Model
OLLAMA_MODEL=llama3.2